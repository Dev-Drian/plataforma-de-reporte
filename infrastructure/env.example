# ============================================
# Configuración para Desarrollo
# ============================================
# Copia este archivo a .env y ajusta los valores según tu entorno
# cp env.example .env

# ============================================
# BASE DE DATOS
# ============================================
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=marketing_seo

# ============================================
# SEGURIDAD
# ============================================
JWT_SECRET=tu-secret-azure

# ============================================
# URLs DEL FRONTEND (para callbacks OAuth)
# ============================================
# AZURE (configuración actual):
FRONTEND_URL=http://plataforma-reporte.centralus.cloudapp.azure.com
VITE_API_BASE_URL=http://plataforma-reporte.centralus.cloudapp.azure.com:4000/api

# Para LOCAL (desarrollo en tu máquina), descomenta estas líneas y comenta las de arriba:
# FRONTEND_URL=http://localhost:3000
# VITE_API_BASE_URL=http://localhost:4000/api

# Para AZURE con IP pública:
# FRONTEND_URL=http://172.202.105.8
# VITE_API_BASE_URL=http://172.202.105.8:4000/api

# ============================================
# OAUTH CREDENTIALS (opcional)
# ============================================
# Si no se configuran, se usan valores por defecto del seeder
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
META_ACCESS_TOKEN=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
