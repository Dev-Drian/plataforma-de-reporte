FROM node:20-alpine

WORKDIR /app

# Copiar package files
COPY package*.json ./

# Instalar dependencias (incluyendo dev para tsx watch)
RUN if [ -f package-lock.json ]; then npm ci; else npm install; fi

# Exponer puerto
EXPOSE 4000

# Comando por defecto (se puede override en docker-compose)
ENTRYPOINT []
CMD ["npm", "run", "dev"]

